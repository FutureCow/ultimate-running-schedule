# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://runuser:runpass@localhost:5432/rundb

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Anthropic Claude ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Garmin credential encryption ─────────────────────────────────────────────
# 32-byte URL-safe base64 key – generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GARMIN_ENCRYPTION_KEY=generate-with-fernet

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
REGISTRATION_OPEN=true   # zet op false om nieuwe registraties te blokkeren
